# Copy to .env to override defaults locally. All variables are optional;
# the defaults in config/settings.py work out of the box.

# Web target (Swag Labs)
# These are NOT secrets: Swag Labs prints these public demo credentials on its
# own login page. They are overridable via env / a gitignored .env, but kept as
# defaults so the suite runs out of the box. Real secrets would live only in
# .env (no defaults committed).
# QA_BASE_WEB_URL=https://www.saucedemo.com
# QA_STANDARD_USER=standard_user
# QA_PASSWORD=secret_sauce

# API target (JSONPlaceholder)
# QA_BASE_API_URL=https://jsonplaceholder.typicode.com

# Runtime
# QA_BROWSER=chromium        # chromium | firefox | webkit (UI suite)
# QA_TIMEOUT_MS=10000        # applied to Playwright waits and the API client
